{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash(git push*)",
        "hooks": [
          {
            "type": "command",
            "command": "pnpm build && pnpm lint",
            "statusMessage": "Enforcing build + lint before push...",
            "asyncRewake": true
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash(pnpm build*)",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-hydration.mjs",
            "statusMessage": "Checking for hydration errors...",
            "asyncRewake": true
          }
        ]
      },
      {
        "matcher": "Bash(gh pr create*)",
        "hooks": [
          {
            "type": "command",
            "command": "node scripts/check-hydration.mjs",
            "statusMessage": "Checking for hydration errors before PR...",
            "asyncRewake": true
          }
        ]
      }
    ]
  }
}
